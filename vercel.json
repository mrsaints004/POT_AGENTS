{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npx turbo build --filter=@pot/backend...",
  "rewrites": [{ "source": "/(.*)", "destination": "/apps/backend/api" }],
  "functions": {
    "apps/backend/api/index.ts": {
      "maxDuration": 60
    }
  }
}
